        }
        lines {
          text: "function PostCard({"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  post,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
