  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport crypto from \"crypto\";\nimport path from \"path\";\nimport Database from \"better-sqlite3\";\nimport { createServer as createViteServer } from \"vite\";\n\nconst app = express();\nconst PORT = 3000;\n\napp.use(express.json());\n\n// In-memory array to simulate KV store for rate-limiting\n// We will store interact:${postID}:${authorToken} as keys with a timestamp\nconst KV_STORE = new Map<string, number>();\n\n// Clean KV store periodically to avoid memory leaks (keys older than 24h)\nsetInterval(() => {\n  const now = Date.now();\n  for (const [key, timestamp] of KV_STORE.entries()) {\n    if (now - timestamp > 24 * 60 * 60 * 1000) {\n      KV_STORE.delete(key);\n    }\n  }\n}, 60 * 60 * 1000); // Check every hour\n\n// Setup SQLite database\nconst db = new Database(\':memory:\'); // Using memory for MVP\n\ndb.exec(`\n  CREATE TABLE IF NOT EXISTS posts (\n    id TEXT PRIMARY KEY,\n    content TEXT,\n    author_name TEXT,\n    author_token TEXT,\n    up_count INTEGER DEFAULT 0,\n    down_count INTEGER DEFAULT 0,\n    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,\n    expires_at DATETIME\n  );\n`);\n\nconst insertPost = db.prepare(`\n  INSERT INTO posts (id, content, author_name, author_token, expires_at)\n  VALUES (?, ?, ?, ?, datetime(\'now\', \'+1 day\'))\n`);\n\nconst selectVisiblePosts = db.prepare(`\n  SELECT * FROM posts \n  WHERE expires_at > datetime(\'now\') AND (up_count - down_count) > -5\n`);\n\nconst selectPostById = db.prepare(`\n  SELECT * FROM posts WHERE id = ?\n`);\n\nconst updatePostInteraction = db.prepare(`\n  UPDATE posts\n  SET up_count = up_count + ?, down_count = down_count + ?\n  WHERE id = ?\n`);\n\nconst deleteExpiredPosts = db.prepare(`\n  DELETE FROM posts WHERE expires_at <= datetime(\'now\')\n`);\n\n// Cron to delete expired posts every hour\nsetInterval(() => {\n  deleteExpiredPosts.run();\n  console.log(\'Cleaned up expired posts.\');\n}, 60 * 60 * 1000);\n\n// Babel Identity logic\nconst SECRET_SALT = process.env.SECRET_SALT || \"whisp-default-salt\";\n\nconst EMOJIS = [\"\360\237\221\273\", \"\360\237\221\275\", \"\360\237\244\226\", \"\360\237\244\240\", \"\360\237\221\276\", \"\360\237\244\241\", \"\360\237\221\271\", \"\360\237\221\272\", \"\360\237\246\211\", \"\360\237\246\207\"];\nconst ADJECTIVES = [\n  \"Silent\", \"Swift\", \"Brave\", \"Calm\", \"Fierce\",\n  \"\320\241\320\272\321\200\321\213\321\202\320\275\321\213\320\271\", \"\320\221\321\213\321\201\321\202\321\200\321\213\320\271\", \"\320\245\321\200\320\260\320\261\321\200\321\213\320\271\", // Russian\n  \"\346\262\211\351\273\230\", \"\346\225\217\346\215\267\", \"\345\213\207\346\225\242\", // Chinese\n  \"\354\241\260\354\232\251\355\225\234\", \"\353\271\240\353\245\270\", \"\354\232\251\352\260\220\355\225\234\", // Korean\n  \"\330\265\330\247\331\205\330\252\", \"\330\263\330\261\331\212\330\271\", \"\330\264\330\254\330\247\330\271\" // Arabic\n];\nconst NOUNS = [\n  \"Shadow\", \"Echo\", \"Whisper\", \"Phantom\", \"Spirit\",\n  \"\320\242\320\265\320\275\321\214\", \"\320\255\321\205\320\276\", \"\320\250\320\265\320\277\320\276\321\202\", // Russian\n  \"\351\230\264\345\275\261\", \"\345\233\236\345\243\260\", \"\350\200\263\350\257\255\", // Chinese\n  \"\352\267\270\353\246\274\354\236\220\", \"\353\251\224\354\225\204\353\246\254\", \"\354\206\215\354\202\255\354\236\204\", // Korean\n  \"\330\270\331\204\", \"\330\265\330\257\331\211\", \"\331\207\331\205\330\263\" // Arabic\n];\n\nfunction generateBabelIdentity(ip: string) {\n  const dateString = new Date().toISOString().split(\'T\')[0];\n  const hash = crypto.createHmac(\'sha256\', SECRET_SALT)\n                     .update(ip + dateString)\n                     .digest(\'hex\');\n  \n  const token = hash;\n  // Convert portions of hash to indices for arrays\n  const emojiIndex = parseInt(hash.slice(0, 2), 16) % EMOJIS.length;\n  const adjIndex = parseInt(hash.slice(2, 4), 16) % ADJECTIVES.length;\n  const nounIndex = parseInt(hash.slice(4, 6), 16) % NOUNS.length;\n  const colorHex = \'#\' + hash.slice(6, 12);\n  \n  const authorName = \\`\\${EMOJIS[emojiIndex]} \\${ADJECTIVES[adjIndex]} \\${NOUNS[nounIndex]}\\`;\n  \n  return { authorToken: token, authorName, colorHex };\n}\n\nfunction calculateGravityScore(post: any) {\n  const up = post.up_count;\n  const down = post.down_count;\n  const createdAt = new Date(post.created_at + \'Z\').getTime(); // Ensure UTC\n  const now = Date.now();\n  const ageInHours = (now - createdAt) / (1000 * 60 * 60);\n  \n  // Gravity score: (UP - DOWN) / (Age in Hours + 2)^1.8\n  const score = (up - down) / Math.pow(Math.max(0, ageInHours) + 2, 1.8);\n  return score;\n}\n\n// API Routes\napp.get(\"/api/identity\", (req, res) => {\n  const ip = req.ip || \'unknown-ip\';\n  const identity = generateBabelIdentity(ip);\n  // Send back identity except the raw token, maybe send an anonymized hash for UI uniqueness validation if need be.\n  // Actually, for creating posts, we just need to confirm we have it server side.\n  // We\'ll send it down so UI can style the current user\'s compose box.\n  res.json({\n    name: identity.authorName,\n    color: identity.colorHex,\n    tokenHash: identity.authorToken.slice(0, 8) // public fragment\n  });\n});\n\napp.post(\"/api/posts\", (req, res) => {\n  const { content } = req.body;\n  if (!content || typeof content !== \'string\' || content.length > 500 || content.trim().length === 0) {\n    return res.status(400).json({ error: \"Invalid post content (max 500 chars)\" });\n  }\n\n  const ip = req.ip || \'unknown-ip\';\n  const { authorName, authorToken } = generateBabelIdentity(ip);\n  const id = crypto.randomBytes(4).toString(\'hex\'); // 8 char hex ID\n  \n  try {\n    insertPost.run(id, content, authorName, authorToken);\n    res.status(201).json({ success: true, id });\n  } catch (err) {\n    console.error(\"Failed to insert post:\", err);\n    res.status(500).json({ error: \"Database error\" });\n  }\n});\n\napp.get(\"/api/posts\", (req, res) => {\n  try {\n    let posts = selectVisiblePosts.all() as any[];\n    \n    // Sort by Gravity Score\n    posts = posts.sort((a, b) => {\n      return calculateGravityScore(b) - calculateGravityScore(a);\n    });\n\n    // Provide the color hex derived from the token to the client, but omit the full token\n    const clientPosts = posts.map(p => {\n      const derivedColor = \'#\' + p.author_token.slice(6, 12);\n      return {\n        id: p.id,\n        content: p.content,\n        author_name: p.author_name,\n        colorHex: derivedColor,\n        up_count: p.up_count,\n        down_count: p.down_count,\n        created_at: p.created_at,\n        expires_at: p.expires_at\n      };\n    });\n\n    res.json(clientPosts);\n  } catch (err) {\n    res.status(500).json({ error: \"Database error\" });\n  }\n});\n\napp.post(\"/api/posts/:id/interact\", (req, res) => {\n  const { id } = req.params;\n  const { action } = req.body; // \'up\' or \'down\'\n\n  if (action !== \'up\' && action !== \'down\') {\n    return res.status(400).json({ error: \"Invalid action\" });\n  }\n\n  const ip = req.ip || \'unknown-ip\';\n  const { authorToken } = generateBabelIdentity(ip);\n  \n  const kvKey = \\`interact:\\${id}:\\${authorToken}\\`;\n  if (KV_STORE.has(kvKey)) {\n    return res.status(429).json({ error: \"Already interacted with this post today\" });\n  }\n\n  const post = selectPostById.get(id) as any;\n  if (!post) {\n    return res.status(404).json({ error: \"Post not found\" });\n  }\n\n  try {\n    const upInc = action === \'up\' ? 1 : 0;\n    const downInc = action === \'down\' ? 1 : 0;\n    \n    updatePostInteraction.run(upInc, downInc, id);\n    KV_STORE.set(kvKey, Date.now());\n    \n    res.json({ success: true });\n  } catch (err) {\n    res.status(500).json({ error: \"Database error\" });\n  }\n});\n\n// Vite middleware for development\nasync function startServer() {\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(\\`Server running on http://localhost:\\${PORT}\\`);\n  });\n}\n\nstartServer();\n"
    }
