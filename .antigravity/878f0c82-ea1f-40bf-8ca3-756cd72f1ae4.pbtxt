    replacement_chunks {
      replacement_content: "import React, { useEffect, useState, useRef } from \'react\';\nimport { ArrowUp, ArrowDown, Clock } from \'lucide-react\';\nimport { clsx, type ClassValue } from \'clsx\';\nimport { twMerge } from \'tailwind-merge\';\n\n// --- Utilities ---\nexport function cn(...inputs: ClassValue[]) {\n  return twMerge(clsx(inputs));\n}\n\nfunction getCountdownValue(expiresAt: string) {\n  const expires = new Date(expiresAt + \'Z\').getTime(); // append Z to parse as UTC from sqlite\n  const now = Date.now();\n  const diff = expires - now;\n  \n  if (diff <= 0) return \"Expired\";\n  \n  const h = Math.floor(diff / (1000 * 60 * 60));\n  const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));\n  \n  if (h > 0) return \\`Disappears in \\${h}h \\${m}m\\`;\n  return \\`Disappears in \\${m}m\\`;\n}\n\n// --- Types ---\ninterface Post {\n  id: string;\n  content: string;\n  author_name: string;\n  colorHex: string;\n  up_count: number;\n  down_count: number;\n  created_at: string;\n  expires_at: string;\n}\n\n// --- Post Card Component ---\nfunction PostCard({ post, onInteract }: { post: Post, onInteract: (id: string, action: \'up\' | \'down\') => void }) {\n  const [timeLeft, setTimeLeft] = useState(getCountdownValue(post.expires_at));\n  \n  // Timer effect\n  useEffect(() => {\n    const timer = setInterval(() => {\n      setTimeLeft(getCountdownValue(post.expires_at));\n    }, 60000); // update every minute\n    return () => clearInterval(timer);\n  }, [post.expires_at]);\n\n  const score = post.up_count - post.down_count;\n  \n  return (\n    <div className=\"bg-white dark:bg-[#1C1C1C] text-black dark:text-white border border-gray-200 dark:border-[#333333] rounded-xl p-5 shadow-sm transition-all hover:shadow-md flex flex-col gap-3\">\n      <div className=\"flex justify-between items-start\">\n        <div className=\"flex items-center gap-3\">\n          <div \n            className=\"w-10 h-10 rounded-full flex-shrink-0\" \n            style={{ backgroundColor: post.colorHex }}\n          />\n          <div>\n            <div className=\"font-semibold text-sm\">\n              {/* Isolate directionality using bdi */}\n              <bdi>{post.author_name}</bdi>\n            </div>\n            <div className=\"text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1 mt-0.5\">\n               <Clock className=\"w-3 h-3\" />\n               {timeLeft}\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      <p className=\"text-sm/relaxed whitespace-pre-wrap mt-1 break-words\">\n        {post.content}\n      </p>\n      \n      <div className=\"flex items-center justify-between mt-2 pt-3 border-t border-gray-100 dark:border-[#2A2A2A]\">\n         <div className=\"flex items-center gap-1\">\n            <button \n              onClick={() => onInteract(post.id, \'up\')}\n              className=\"p-2 hover:bg-gray-100 dark:hover:bg-[#2A2A2A] rounded-full transition-colors group cursor-pointer\"\n              aria-label=\"Upvote\"\n            >\n              <ArrowUp className=\"w-4 h-4 text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors\" />\n            </button>\n            <span className={cn(\n              \"text-sm font-medium w-6 text-center tabular-nums\",\n              score > 0 ? \"text-black dark:text-white\" : score < 0 ? \"text-gray-400\" : \"text-gray-500\"\n            )}>\n              {score > 0 ? \\`+\\${score}\\` : score}\n            </span>\n            <button \n              onClick={() => onInteract(post.id, \'down\')}\n              className=\"p-2 hover:bg-gray-100 dark:hover:bg-[#2A2A2A] rounded-full transition-colors group cursor-pointer\"\n              aria-label=\"Downvote\"\n            >\n              <ArrowDown className=\"w-4 h-4 text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors\" />\n            </button>\n         </div>\n      </div>\n    </div>\n  );\n}\n\n// --- Main App ---\nexport default function App() {\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [content, setContent] = useState(\'\');\n  const [isDarkMode, setIsDarkMode] = useState(false);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [identity, setIdentity] = useState<{name: string, color: string} | null>(null);\n  \n  // Theme Toggle Effect\n  useEffect(() => {\n    if (isDarkMode) {\n      document.documentElement.classList.add(\'dark\');\n    } else {\n      document.documentElement.classList.remove(\'dark\');\n    }\n  }, [isDarkMode]);\n\n  // Initial Fetch\n  useEffect(() => {\n    // Check system preference once\n    if (window.matchMedia && window.matchMedia(\'(prefers-color-scheme: dark)\').matches) {\n       setIsDarkMode(true);\n    }\n    fetchIdentity();\n    fetchPosts();\n    \n    // Auto refresh feed every 30s\n    const refresh = setInterval(fetchPosts, 30000);\n    return () => clearInterval(refresh);\n  }, []);\n\n  const fetchIdentity = async () => {\n    try {\n      const res = await fetch(\'/api/identity\');\n      const data = await res.json();\n      if (res.ok) setIdentity(data);\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  const fetchPosts = async () => {\n    try {\n      const res = await fetch(\'/api/posts\');\n      const data = await res.json();\n      if (res.ok) setPosts(data);\n    } catch (err) {\n      console.error(\"Failed to fetch posts\", err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!content.trim() || content.length > 500) return;\n    setIsSubmitting(true);\n    try {\n      const res = await fetch(\'/api/posts\', {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ content })\n      });\n      if (res.ok) {\n        setContent(\'\');\n        fetchPosts(); // Refresh feed immediately\n      }\n    } catch (err) {\n      console.error(\"Failed to post\", err);\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleInteract = async (id: string, action: \'up\' | \'down\') => {\n    try {\n      const res = await fetch(\\`/api/posts/\\${id}/interact\\`, {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ action })\n      });\n      \n      if (res.ok) {\n        // Optimistic update\n        setPosts(prev => prev.map(p => {\n          if (p.id === id) {\n            return {\n              ...p,\n              up_count: action === \'up\' ? p.up_count + 1 : p.up_count,\n              down_count: action === \'down\' ? p.down_count + 1 : p.down_count\n            };\n          }\n          return p;\n        }));\n        // Note: we let the automatic refresh handle resorts based on new gravity score.\n      } else {\n        const err = await res.json();\n        alert(err.error || \"Cannot interact again\");\n      }\n    } catch (err) {\n      console.error(\"Interaction failed\", err);\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#FDFDFD] dark:bg-black text-black dark:text-white font-sans transition-colors duration-200\">\n      <div className=\"max-w-2xl mx-auto w-full px-4 sm:px-6 py-8 flex flex-col gap-8\">\n        \n        {/* Header */}\n        <header className=\"flex items-center justify-between\">\n          <h1 className=\"text-2xl font-bold tracking-tight lowercase\">whisp.</h1>\n          <button\n            onClick={() => setIsDarkMode(!isDarkMode)}\n            className=\"text-sm font-medium border border-gray-300 dark:border-gray-700 px-3 py-1.5 rounded-full hover:bg-gray-100 dark:hover:bg-[#1C1C1C] transition-colors cursor-pointer\"\n          >\n            {isDarkMode ? \'Light\' : \'Dark\'} Mode\n          </button>\n        </header>\n\n        {/* Compose Box */}\n        <section className=\"bg-white dark:bg-[#111111] border border-gray-200 dark:border-[#333333] rounded-2xl p-5 sm:p-6 shadow-sm\">\n          <form onSubmit={handleSubmit} className=\"flex flex-col gap-4\">\n            <div className=\"flex items-start gap-4\">\n               {identity ? (\n                  <div \n                    className=\"w-10 h-10 rounded-full flex-shrink-0 mt-1\" \n                    style={{ backgroundColor: identity.color }}\n                  />\n               ) : (\n                  <div className=\"w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-800 flex-shrink-0 animate-pulse mt-1\" />\n               )}\n               <div className=\"flex-1\">\n                 <textarea \n                   className=\"w-full bg-transparent resize-none border-none focus:ring-0 text-base placeholder-gray-400 dark:placeholder-gray-600 outline-none\"\n                   rows={3}\n                   placeholder=\"Whisper something to the void...\"\n                   value={content}\n                   onChange={e => setContent(e.target.value)}\n                   maxLength={500}\n                 />\n               </div>\n            </div>\n            \n            <div className=\"flex items-center justify-between border-t border-gray-100 dark:border-[#2A2A2A] pt-4 mt-2\">\n              <span className={cn(\n                \"text-xs font-medium\",\n                content.length > 450 ? \"text-red-500\" : \"text-gray-400\"\n              )}>\n                {content.length} / 500\n              </span>\n              <button \n                type=\"submit\" \n                disabled={!content.trim() || isSubmitting}\n                className=\"bg-black dark:bg-white text-white dark:text-black font-semibold text-sm px-6 py-2.5 rounded-full hover:opacity-80 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer\"\n              >\n                {isSubmitting ? \'Whispering...\' : \'Whisper\'}\n              </button>\n            </div>\n          </form>\n        </section>\n\n        {/* Feed */}\n        <main className=\"flex flex-col gap-4 pb-20\">\n          {posts.length === 0 ? (\n            <div className=\"text-center py-20 text-gray-400 dark:text-gray-600\">\n               <p>The void is currently empty.</p>\n               <p className=\"text-sm mt-1\">Be the first to whisper.</p>\n            </div>\n          ) : (\n            posts.map(post => (\n              <PostCard \n                key={post.id} \n                post={post} \n                onInteract={handleInteract} \n              />\n            ))\n          )}\n        </main>\n        \n      </div>\n    </div>\n  );\n}\n"
    }
