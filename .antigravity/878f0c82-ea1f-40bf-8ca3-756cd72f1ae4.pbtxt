          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}: {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  post: Post;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  onInteract: (id: string, action: \"up\" | \"down\") => void;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  onReply: (post: Post) => void;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  isDark: boolean;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const [timeLeft, setTimeLeft] = useState(getCountdownValue(post.expires_at));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const [isSharing, setIsSharing] = useState(false);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const exportContainerRef = useRef<HTMLDivElement>(null);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // Timer effect"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  useEffect(() => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const timer = setInterval(() => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      setTimeLeft(getCountdownValue(post.expires_at));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    }, 60000);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return () => clearInterval(timer);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  }, [post.expires_at]);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const score = post.up_count - post.down_count;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const handleShare = async () => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    setIsSharing(true);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    try {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      // Small timeout to allow render to flush before capturing"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      await new Promise((r) => setTimeout(r, 100));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (!exportContainerRef.current) return;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const blob = await toBlob(exportContainerRef.current, {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        backgroundColor: isDark ? \"#0a0a0a\" : \"#ffffff\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        pixelRatio: 2, // Retained high quality"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (!blob) return;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      const file = new File([blob], `whisp-${post.id}.png`, {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        type: \"image/png\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      if (navigator.canShare && navigator.canShare({ files: [file] })) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        try {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          await navigator.share({"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            files: [file],"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            title: \"A whisper from whisp\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          });"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        } catch (err) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          console.log(\"Share failed, falling back to download\", err);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          downloadBlob(blob, `whisp-${post.id}.png`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        downloadBlob(blob, `whisp-${post.id}.png`);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    } catch (err) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      console.error(\"Failed to share\", err);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    } finally {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      setIsSharing(false);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  };"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const downloadBlob = (blob: Blob, filename: string) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const url = URL.createObjectURL(blob);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const a = document.createElement(\"a\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    a.href = url;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    a.download = filename;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    document.body.appendChild(a);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    a.click();"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    document.body.removeChild(a);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    URL.revokeObjectURL(url);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
