        target_content: "function ShareCanvas({ post, isDark }: { post: Post; isDark: boolean }) {\n  return (\n    <div\n      className={cn(\n        \"w-[400px] p-6 rounded-3xl flex flex-col gap-4 font-sans border-2 items-start justify-center\",\n        isDark\n          ? \"bg-[#0a0a0a] text-white border-white/10\"\n          : \"bg-white text-black border-black/10\",\n      )}\n      style={{ isolation: \"isolate\" }}\n    >\n      <div className=\"flex items-center gap-3\">\n        <div\n          className=\"w-10 h-10 rounded-full flex-shrink-0\"\n          style={{ backgroundColor: post.colorHex }}\n        />\n        <div className=\"font-semibold text-base\">\n          <bdi>{post.author_name}</bdi>\n        </div>\n      </div>\n      <p className=\"text-xl leading-relaxed whitespace-pre-wrap break-words font-medium mt-2\">\n        {post.content}\n      </p>\n      <div\n        className={cn(\n          \"mt-6 text-sm font-mono opacity-50 flex flex-col gap-1\",\n          isDark ? \"text-gray-400\" : \"text-gray-500\",\n        )}\n      >\n        <span>whispered on whisp.</span>\n      </div>\n    </div>\n  );\n}"
        replacement_content: "function ShareCanvas({ \n  post, \n  isDark,\n  timeLeft,\n  replyCount\n}: { \n  post: Post; \n  isDark: boolean;\n  timeLeft: string;\n  replyCount: number;\n}) {\n  const score = post.up_count - post.down_count;\n  return (\n    <div\n      className={cn(\n        \"w-[400px] p-6 rounded-3xl flex flex-col gap-4 font-sans border-2 items-start justify-center\",\n        isDark\n          ? \"bg-[#0a0a0a] text-white border-white/10\"\n          : \"bg-white text-black border-black/10\",\n      )}\n      style={{ isolation: \"isolate\" }}\n    >\n      <div className=\"flex w-full justify-between items-start\">\n        <div className=\"flex items-center gap-3\">\n          <div\n            className=\"w-10 h-10 rounded-full flex-shrink-0\"\n            style={{ backgroundColor: post.colorHex }}\n          />\n          <div className=\"font-semibold text-base\">\n            <bdi>{post.author_name}</bdi>\n          </div>\n        </div>\n        <div className=\"text-xs font-mono opacity-60 flex items-center gap-1 mt-1\">\n          <Clock className=\"w-3 h-3\" />\n          {timeLeft}\n        </div>\n      </div>\n      <p className=\"text-xl leading-relaxed whitespace-pre-wrap break-words font-medium mt-2 w-full\">\n        {post.content}\n      </p>\n      \n      <div className=\"flex items-center gap-4 mt-2 font-mono text-sm opacity-60 w-full\">\n        <div className=\"flex items-center gap-1\">\n          <ArrowUp className=\"w-4 h-4\" />\n          <span>{post.up_count}</span>\n        </div>\n        <div className=\"flex items-center gap-1\">\n          <ArrowDown className=\"w-4 h-4\" />\n          <span>{post.down_count}</span>\n        </div>\n        <div className=\"flex items-center gap-1\">\n          <MessageCircle className=\"w-4 h-4\" />\n          <span>{replyCount}</span>\n        </div>\n      </div>\n      \n      <div\n        className={cn(\n          \"mt-6 text-sm font-mono opacity-40 flex flex-col gap-1 w-full text-center border-t pt-4\",\n          isDark ? \"border-white/10\" : \"border-black/10\"\n        )}\n      >\n        <span>whispered on whisp.</span>\n      </div>\n    </div>\n  );\n}"
