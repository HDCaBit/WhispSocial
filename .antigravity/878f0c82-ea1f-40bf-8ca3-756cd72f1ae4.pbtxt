    replacement_infos {
      original_chunk {
        target_content: "      const canvas = await html2canvas(exportContainerRef.current, {\n        backgroundColor: isDark ? \"#0a0a0a\" : \"#ffffff\",\n        scale: 2, // Retained high quality\n        useCORS: true,\n      });\n\n      canvas.toBlob(async (blob) => {\n        if (!blob) return;\n        const file = new File([blob], `whisp-${post.id}.png`, {\n          type: \"image/png\",\n        });\n\n        if (navigator.canShare && navigator.canShare({ files: [file] })) {\n          try {\n            await navigator.share({\n              files: [file],\n              title: \"A whisper from whisp\",\n            });\n          } catch (err) {\n            console.log(\"Share failed, falling back to download\", err);\n            downloadBlob(blob, `whisp-${post.id}.png`);\n          }\n        } else {\n          downloadBlob(blob, `whisp-${post.id}.png`);\n        }\n      });"
        replacement_content: "      const blob = await toBlob(exportContainerRef.current, {\n        backgroundColor: isDark ? \"#0a0a0a\" : \"#ffffff\",\n        pixelRatio: 2, // Retained high quality\n      });\n\n      if (!blob) return;\n\n      const file = new File([blob], `whisp-${post.id}.png`, {\n        type: \"image/png\",\n      });\n\n      if (navigator.canShare && navigator.canShare({ files: [file] })) {\n        try {\n          await navigator.share({\n            files: [file],\n            title: \"A whisper from whisp\",\n          });\n        } catch (err) {\n          console.log(\"Share failed, falling back to download\", err);\n          downloadBlob(blob, `whisp-${post.id}.png`);\n        }\n      } else {\n        downloadBlob(blob, `whisp-${post.id}.png`);\n      }"
      }
      num_matches: 1
    }
