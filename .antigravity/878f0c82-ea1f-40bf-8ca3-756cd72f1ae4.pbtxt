  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useEffect, useState, useRef } from \'react\';\nimport { ArrowUp, ArrowDown, Clock, MessageCircle, Share, X } from \'lucide-react\';\nimport { clsx, type ClassValue } from \'clsx\';\nimport { twMerge } from \'tailwind-merge\';\nimport html2canvas from \'html2canvas\';\n\n// --- Utilities ---\nexport function cn(...inputs: ClassValue[]) {\n  return twMerge(clsx(inputs));\n}\n\nfunction getCountdownValue(expiresAt: string) {\n  const expires = new Date(expiresAt + \'Z\').getTime();\n  const now = Date.now();\n  const diff = expires - now;\n  \n  if (diff <= 0) return \"Expired\";\n  \n  const h = Math.floor(diff / (1000 * 60 * 60));\n  const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));\n  \n  if (h > 0) return `${h}h ${m}m`;\n  return `${m}m`;\n}\n\n// --- Types ---\ninterface Post {\n  id: string;\n  content: string;\n  author_name: string;\n  colorHex: string;\n  up_count: number;\n  down_count: number;\n  created_at: string;\n  expires_at: string;\n  reply_to: string | null;\n}\n\n// --- Share Canvas Component ---\n// This is isolated completely so we can render it off-screen and take a screenshot\nfunction ShareCanvas({ post, isDark }: { post: Post, isDark: boolean }) {\n  return (\n    <div \n      className={cn(\n        \"w-[400px] p-6 rounded-3xl flex flex-col gap-4 font-sans border-2 items-start justify-center\",\n        isDark ? \"bg-[#0a0a0a] text-white border-white/10\" : \"bg-white text-black border-black/10\"\n      )}\n      style={{ isolation: \'isolate\' }}\n    >\n      <div className=\"flex items-center gap-3\">\n        <div \n          className=\"w-10 h-10 rounded-full flex-shrink-0\" \n          style={{ backgroundColor: post.colorHex }}\n        />\n        <div className=\"font-semibold text-base\">\n          <bdi>{post.author_name}</bdi>\n        </div>\n      </div>\n      <p className=\"text-xl leading-relaxed whitespace-pre-wrap break-words font-medium mt-2\">\n        {post.content}\n      </p>\n      <div className={cn(\"mt-6 text-sm font-mono opacity-50 flex flex-col gap-1\", isDark ? \"text-gray-400\" : \"text-gray-500\")}>\n        <span>whispered on whisp.</span>\n      </div>\n    </div>\n  );\n}\n\n// --- Post Card Component ---\nfunction PostCard({ \n  post, \n  onInteract,\n  onReply,\n  isDark\n}: { \n  post: Post, \n  onInteract: (id: string, action: \'up\' | \'down\') => void,\n  onReply: (post: Post) => void,\n  isDark: boolean\n}) {\n  const [timeLeft, setTimeLeft] = useState(getCountdownValue(post.expires_at));\n  const [isSharing, setIsSharing] = useState(false);\n  const exportContainerRef = useRef<HTMLDivElement>(null);\n  \n  // Timer effect\n  useEffect(() => {\n    const timer = setInterval(() => {\n      setTimeLeft(getCountdownValue(post.expires_at));\n    }, 60000);\n    return () => clearInterval(timer);\n  }, [post.expires_at]);\n\n  const score = post.up_count - post.down_count;\n\n  const handleShare = async () => {\n    if (!exportContainerRef.current) return;\n    setIsSharing(true);\n    try {\n      // Small timeout to allow render to flush before capturing\n      await new Promise(r => setTimeout(r, 50));\n      const canvas = await html2canvas(exportContainerRef.current, {\n        backgroundColor: isDark ? \'#0a0a0a\' : \'#ffffff\',\n        scale: 2, // Retained high quality\n        useCORS: true,\n      });\n\n      canvas.toBlob(async (blob) => {\n        if (!blob) return;\n        const file = new File([blob], `whisp-${post.id}.png`, { type: \'image/png\' });\n        \n        if (navigator.canShare && navigator.canShare({ files: [file] })) {\n          try {\n            await navigator.share({\n              files: [file],\n              title: \'A whisper from whisp\',\n            });\n          } catch (err) {\n            console.log(\'Share failed, falling back to download\', err);\n            downloadBlob(blob, `whisp-${post.id}.png`);\n          }\n        } else {\n          downloadBlob(blob, `whisp-${post.id}.png`);\n        }\n      });\n    } catch (err) {\n      console.error(\"Failed to share\", err);\n    } finally {\n      setIsSharing(false);\n    }\n  };\n\n  const downloadBlob = (blob: Blob, filename: string) => {\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement(\'a\');\n    a.href = url;\n    a.download = filename;\n    document.body.appendChild(a);\n    a.click();\n    document.body.removeChild(a);\n    URL.revokeObjectURL(url);\n  };\n  \n  return (\n    <div className=\"border border-gray-200 dark:border-gray-800 rounded-xl p-4 mb-4 shadow-sm bg-white dark:bg-[#0a0a0a] flex flex-col gap-3 relative\">\n      <div className=\"flex justify-between items-start\">\n        <div className=\"flex items-center gap-3\">\n          <div \n            className=\"w-8 h-8 rounded-full flex-shrink-0\" \n            style={{ backgroundColor: post.colorHex }}\n          />\n          <div className=\"font-semibold text-sm text-black dark:text-white\">\n            <bdi>{post.author_name}</bdi>\n          </div>\n        </div>\n        <div className=\"text-xs text-gray-500 font-mono flex items-center gap-1\">\n           Disappears in {timeLeft}\n        </div>\n      </div>\n      \n      <p className=\"text-sm/relaxed whitespace-pre-wrap mt-1 break-words text-black dark:text-white\">\n        {post.content}\n      </p>\n      \n      <div className=\"flex items-center gap-4 mt-2 pt-2 text-gray-500 dark:text-gray-400\">\n         <div className=\"flex items-center gap-1\">\n            <button \n              onClick={() => onInteract(post.id, \'up\')}\n              className=\"p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded hover:text-black dark:hover:text-white transition-colors cursor-pointer\"\n            >\n              <ArrowUp className=\"w-4 h-4\" />\n            </button>\n            <span className=\"text-xs font-mono w-6 text-center tabular-nums\">\n              {score}\n            </span>\n            <button \n              onClick={() => onInteract(post.id, \'down\')}\n              className=\"p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded hover:text-black dark:hover:text-white transition-colors cursor-pointer\"\n            >\n              <ArrowDown className=\"w-4 h-4\" />\n            </button>\n         </div>\n         <button \n            onClick={() => onReply(post)}\n            className=\"p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded hover:text-black dark:hover:text-white transition-colors cursor-pointer flex items-center gap-1\"\n          >\n            <MessageCircle className=\"w-4 h-4\" />\n          </button>\n          \n          <button \n            onClick={handleShare}\n            disabled={isSharing}\n            className=\"ml-auto p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded hover:text-black dark:hover:text-white transition-colors cursor-pointer flex items-center gap-1 disabled:opacity-50\"\n          >\n            <Share className=\"w-4 h-4\" />\n          </button>\n      </div>\n\n      {/* Hidden export layout strictly for HTML2Canvas */}\n      <div className=\"absolute top-0 left-0 -z-50 opacity-0 pointer-events-none w-[0px] h-[0px] overflow-hidden\">\n         {isSharing && (\n            <div ref={exportContainerRef}>\n               <ShareCanvas post={post} isDark={isDark} />\n            </div>\n         )}\n      </div>\n    </div>\n  );\n}\n\n// --- Main App ---\nexport default function App() {\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [content, setContent] = useState(\'\');\n  const [isDarkMode, setIsDarkMode] = useState(false);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [replyingTo, setReplyingTo] = useState<Post | null>(null);\n  \n  // Theme Toggle Effect\n  useEffect(() => {\n    if (isDarkMode) {\n      document.documentElement.classList.add(\'dark\');\n    } else {\n      document.documentElement.classList.remove(\'dark\');\n    }\n  }, [isDarkMode]);\n\n  // Initial Fetch\n  useEffect(() => {\n    if (window.matchMedia && window.matchMedia(\'(prefers-color-scheme: dark)\').matches) {\n       setIsDarkMode(true);\n    }\n    fetchPosts();\n    const refresh = setInterval(fetchPosts, 30000);\n    return () => clearInterval(refresh);\n  }, []);\n\n  const fetchPosts = async () => {\n    try {\n      const res = await fetch(\'/api/posts\');\n      const data = await res.json();\n      if (res.ok) setPosts(data);\n    } catch (err) {\n      console.error(\"Failed to fetch posts\", err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!content.trim() || content.length > 500) return;\n    setIsSubmitting(true);\n    try {\n      const res = await fetch(\'/api/posts\', {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ \n           content,\n           reply_to: replyingTo?.id || null\n        })\n      });\n      if (res.ok) {\n        setContent(\'\');\n        setReplyingTo(null);\n        fetchPosts(); \n      }\n    } catch (err) {\n      console.error(\"Failed to post\", err);\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleInteract = async (id: string, action: \'up\' | \'down\') => {\n    try {\n      const res = await fetch(`/api/posts/${id}/interact`, {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ action })\n      });\n      \n      if (res.ok) {\n        setPosts(prev => prev.map(p => {\n          if (p.id === id) {\n            return {\n              ...p,\n              up_count: action === \'up\' ? p.up_count + 1 : p.up_count,\n              down_count: action === \'down\' ? p.down_count + 1 : p.down_count\n            };\n          }\n          return p;\n        }));\n      } else {\n        const err = await res.json();\n        alert(err.error || \"Cannot interact again\");\n      }\n    } catch (err) {\n      console.error(\"Interaction failed\", err);\n    }\n  };\n\n  // Group threads\n  const parents = posts.filter(p => !p.reply_to);\n  const replies = posts.filter(p => p.reply_to);\n\n  return (\n    <div className=\"min-h-screen bg-white dark:bg-[#0a0a0a] text-black dark:text-white font-sans selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black\">\n      \n      {/* Sticky Header */}\n      <header className=\"sticky top-0 z-10 backdrop-blur-md bg-white/80 dark:bg-black/80 border-b border-gray-100 dark:border-gray-900 px-4 py-3\">\n         <div className=\"max-w-xl mx-auto w-full flex items-center justify-between\">\n            <h1 className=\"text-xl font-bold font-mono tracking-tight lowercase\">whisp</h1>\n            <div className=\"flex items-center gap-3\">\n              <button\n                onClick={() => setIsDarkMode(!isDarkMode)}\n                className=\"text-xs font-mono border border-gray-200 dark:border-gray-800 px-3 py-1.5 rounded bg-transparent hover:bg-gray-100 dark:hover:bg-gray-900 transition-colors cursor-pointer\"\n              >\n                {isDarkMode ? \'light\' : \'dark\'}\n              </button>\n              <button\n                onClick={() => window.scrollTo({ top: 0, behavior: \'smooth\' })}\n                className=\"text-xs font-mono bg-black text-white dark:bg-white dark:text-black px-4 py-1.5 rounded hover:opacity-80 transition-opacity cursor-pointer\"\n              >\n                new\n              </button>\n            </div>\n         </div>\n      </header>\n\n      <div className=\"max-w-xl mx-auto w-full px-4 sm:px-0 py-8 flex flex-col gap-6 relative\">\n        \n        {/* Compose Box */}\n        <section className=\"bg-white dark:bg-[#0a0a0a] border-b-2 border-transparent dark:border-gray-800 pb-6 mb-2\">\n          {replyingTo && (\n            <div className=\"mb-3 p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg flex items-start justify-between\">\n               <div className=\"flex flex-col gap-1 overflow-hidden\">\n                 <span className=\"text-xs font-semibold text-gray-500\">Replying to {replyingTo.author_name}</span>\n                 <p className=\"text-sm truncate opacity-80\">{replyingTo.content}</p>\n               </div>\n               <button \n                 onClick={() => setReplyingTo(null)}\n                 className=\"text-gray-400 hover:text-black dark:hover:text-white p-1\"\n               >\n                 <X className=\"w-4 h-4\" />\n               </button>\n            </div>\n          )}\n          <form onSubmit={handleSubmit} className=\"flex flex-col gap-4 relative\">\n            <textarea \n              className=\"w-full bg-transparent resize-none border border-gray-200 dark:border-gray-800 rounded-xl p-4 focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white text-base placeholder-gray-400 dark:placeholder-gray-600 outline-none transition-all\"\n              rows={3}\n              placeholder={replyingTo ? \"Write your reply...\" : \"Whisper something to the void...\"}\n              value={content}\n              onChange={e => setContent(e.target.value)}\n              maxLength={500}\n            />\n            \n            <div className=\"flex items-center justify-between absolute bottom-3 right-3 left-4 pointer-events-none\">\n              <span className={cn(\n                \"text-xs font-mono\",\n                content.length > 450 ? \"text-red-500\" : \"text-gray-400\"\n              )}>\n                {content.length} / 500\n              </span>\n              <button \n                type=\"submit\" \n                disabled={!content.trim() || isSubmitting}\n                className=\"pointer-events-auto bg-black dark:bg-white text-white dark:text-black font-semibold text-sm px-6 py-2 rounded-full hover:opacity-80 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer\"\n              >\n                {isSubmitting ? \'...\' : replyingTo ? \'Reply\' : \'Post\'}\n              </button>\n            </div>\n          </form>\n        </section>\n\n        {/* Feed */}\n        <main className=\"flex flex-col pb-20\">\n          {parents.length === 0 ? (\n            <div className=\"text-center py-20 text-gray-400 font-mono text-sm\">\n               The void is currently empty.\n            </div>\n          ) : (\n            parents.map(post => (\n              <div key={post.id} className=\"relative\">\n                <PostCard \n                  post={post} \n                  onInteract={handleInteract} \n                  onReply={setReplyingTo}\n                  isDark={isDarkMode}\n                />\n                \n                {/* Render Replies below the parent */}\n                {replies.filter(r => r.reply_to === post.id).length > 0 && (\n                  <div className=\"pl-6 md:pl-10 relative flex flex-col gap-0 border-l-2 border-gray-100 dark:border-gray-900 ml-4 mb-4 mt-[-10px]\">\n                     {replies.filter(r => r.reply_to === post.id).map(reply => (\n                        <div key={reply.id} className=\"mt-4\">\n                           <PostCard \n                              post={reply} \n                              onInteract={handleInteract} \n                              onReply={() => {\n                                 // Focus reply input handling by replying to the same original post or thread parent \n                                 setReplyingTo(post);\n                                 window.scrollTo({ top: 0, behavior: \'smooth\' });\n                              }}\n                              isDark={isDarkMode}\n                           />\n                        </div>\n                     ))}\n                  </div>\n                )}\n              </div>\n            ))\n          )}\n        </main>\n      </div>\n    </div>\n  );\n}"
