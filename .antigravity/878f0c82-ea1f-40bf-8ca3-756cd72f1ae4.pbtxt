    instruction: "Update App component to implement bottom compose area and new header buttons"
    replacement_infos {
      original_chunk {
        target_content: "// --- Main App ---\nexport default function App() {\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [content, setContent] = useState(\"\");\n  const [isDarkMode, setIsDarkMode] = useState(false);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [replyingTo, setReplyingTo] = useState<Post | null>(null);\n\n  // Theme Toggle Effect\n  useEffect(() => {\n    if (isDarkMode) {\n      document.documentElement.classList.add(\"dark\");\n    } else {\n      document.documentElement.classList.remove(\"dark\");\n    }\n  }, [isDarkMode]);\n\n  // Initial Fetch\n  useEffect(() => {\n    if (\n      window.matchMedia &&\n      window.matchMedia(\"(prefers-color-scheme: dark)\").matches\n    ) {\n      setIsDarkMode(true);\n    }\n    fetchPosts();\n    const refresh = setInterval(fetchPosts, 30000);\n    return () => clearInterval(refresh);\n  }, []);\n\n  const fetchPosts = async () => {\n    try {\n      const res = await fetch(\"/api/posts\");\n      const data = await res.json();\n      if (res.ok) setPosts(data);\n    } catch (err) {\n      console.error(\"Failed to fetch posts\", err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!content.trim() || content.length > 500) return;\n    setIsSubmitting(true);\n    try {\n      const res = await fetch(\"/api/posts\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          content,\n          reply_to: replyingTo?.id || null,\n        }),\n      });\n      if (res.ok) {\n        setContent(\"\");\n        setReplyingTo(null);\n        fetchPosts();\n      }\n    } catch (err) {\n      console.error(\"Failed to post\", err);\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleInteract = async (id: string, action: \"up\" | \"down\") => {\n    try {\n      const res = await fetch(`/api/posts/${id}/interact`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ action }),\n      });\n\n      if (res.ok) {\n        setPosts((prev) =>\n          prev.map((p) => {\n            if (p.id === id) {\n              return {\n                ...p,\n                up_count: action === \"up\" ? p.up_count + 1 : p.up_count,\n                down_count: action === \"down\" ? p.down_count + 1 : p.down_count,\n              };\n            }\n            return p;\n          }),\n        );\n      } else {\n        const err = await res.json();\n        alert(err.error || \"Cannot interact again\");\n      }\n    } catch (err) {\n      console.error(\"Interaction failed\", err);\n    }\n  };\n\n  // Group threads\n  const parents = posts.filter((p) => !p.reply_to);\n  const replies = posts.filter((p) => p.reply_to);\n\n  return (\n    <div className=\"min-h-screen bg-white dark:bg-[#0a0a0a] text-black dark:text-white font-sans selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black\">\n      {/* Sticky Header */}\n      <header className=\"sticky top-0 z-10 backdrop-blur-md bg-white/80 dark:bg-black/80 border-b border-gray-100 dark:border-gray-900 px-4 py-3\">\n        <div className=\"max-w-xl mx-auto w-full flex items-center justify-between\">\n          <h1 className=\"text-xl font-bold font-mono tracking-tight lowercase\">\n            whisp\n          </h1>\n          <div className=\"flex items-center gap-3\">\n            <button\n              onClick={() => setIsDarkMode(!isDarkMode)}\n              className=\"text-xs font-mono border border-gray-200 dark:border-gray-800 px-3 py-1.5 rounded bg-transparent hover:bg-gray-100 dark:hover:bg-gray-900 transition-colors cursor-pointer\"\n            >\n              {isDarkMode ? \"light\" : \"dark\"}\n            </button>\n            <button\n              onClick={() => window.scrollTo({ top: 0, behavior: \"smooth\" })}\n              className=\"text-xs font-mono bg-black text-white dark:bg-white dark:text-black px-4 py-1.5 rounded hover:opacity-80 transition-opacity cursor-pointer\"\n            >\n              new\n            </button>\n          </div>\n        </div>\n      </header>\n\n      <div className=\"max-w-xl mx-auto w-full px-4 sm:px-0 py-8 flex flex-col gap-6 relative\">\n        {/* Compose Box */}\n        <section className=\"bg-white dark:bg-[#0a0a0a] border-b-2 border-transparent dark:border-gray-800 pb-6 mb-2\">\n          {replyingTo && (\n            <div className=\"mb-3 p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg flex items-start justify-between\">\n              <div className=\"flex flex-col gap-1 overflow-hidden\">\n                <span className=\"text-xs font-semibold text-gray-500\">\n                  Replying to {replyingTo.author_name}\n                </span>\n                <p className=\"text-sm truncate opacity-80\">\n                  {replyingTo.content}\n                </p>\n              </div>\n              <button\n                onClick={() => setReplyingTo(null)}\n                className=\"text-gray-400 hover:text-black dark:hover:text-white p-1\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n          )}\n          <form onSubmit={handleSubmit} className=\"flex flex-col gap-3\">\n            <textarea\n              className=\"w-full bg-transparent resize-none border border-gray-200 dark:border-gray-800 rounded-xl p-4 min-h-[100px] focus:ring-1 focus:ring-black dark:focus:ring-white focus:border-black dark:focus:border-white text-base placeholder-gray-400 dark:placeholder-gray-600 outline-none transition-all\"\n              placeholder={\n                replyingTo\n                  ? \"Write your reply...\"\n                  : \"Whisper something to the void...\"\n              }\n              value={content}\n              onChange={(e) => setContent(e.target.value)}\n              maxLength={500}\n            />\n\n            <div className=\"flex items-center justify-between px-1\">\n              <span\n                className={cn(\n                  \"text-xs font-mono\",\n                  content.length > 450 ? \"text-red-500\" : \"text-gray-400\",\n                )}\n              >\n                {content.length} / 500\n              </span>\n              <button\n                type=\"submit\"\n                disabled={!content.trim() || isSubmitting}\n                className=\"bg-black dark:bg-white text-white dark:text-black font-semibold text-sm px-6 py-2 rounded-full hover:opacity-80 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer\"\n              >\n                {isSubmitting ? \"...\" : replyingTo ? \"Reply\" : \"Post\"}\n              </button>\n            </div>\n          </form>\n        </section>\n\n        {/* Feed */}\n        <main className=\"flex flex-col pb-20\">\n          {parents.length === 0 ? (\n            <div className=\"text-center py-20 text-gray-400 font-mono text-sm\">\n              The void is currently empty.\n            </div>\n          ) : (\n            parents.map((post) => (\n              <div key={post.id} className=\"relative\">\n                <PostCard\n                  post={post}\n                  onInteract={handleInteract}\n                  onReply={setReplyingTo}\n                  isDark={isDarkMode}\n                />\n\n                {/* Render Replies below the parent */}\n                {replies.filter((r) => r.reply_to === post.id).length > 0 && (\n                  <div className=\"pl-6 md:pl-10 relative flex flex-col gap-0 border-l-2 border-gray-100 dark:border-gray-900 ml-4 mb-4 mt-[-10px]\">\n                    {replies\n                      .filter((r) => r.reply_to === post.id)\n                      .map((reply) => (\n                        <div key={reply.id} className=\"mt-4\">\n                          <PostCard\n                            post={reply}\n                            onInteract={handleInteract}\n                            onReply={() => {\n                              // Focus reply input handling by replying to the same original post or thread parent\n                              setReplyingTo(post);\n                              window.scrollTo({ top: 0, behavior: \"smooth\" });\n                            }}\n                            isDark={isDarkMode}\n                          />\n                        </div>\n                      ))}\n                  </div>\n                )}\n              </div>\n            ))\n          )}\n        </main>\n      </div>\n    </div>\n  );\n}"
        replacement_content: "// --- Main App ---\nexport default function App() {\n  const [posts, setPosts] = useState<Post[]>([]);\n  const [content, setContent] = useState(\"\");\n  const [isDarkMode, setIsDarkMode] = useState(false);\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [replyingTo, setReplyingTo] = useState<Post | null>(null);\n  const [isComposing, setIsComposing] = useState(false);\n  const inputRef = useRef<HTMLTextAreaElement>(null);\n\n  // Theme Toggle Effect\n  useEffect(() => {\n    if (isDarkMode) {\n      document.documentElement.classList.add(\"dark\");\n    } else {\n      document.documentElement.classList.remove(\"dark\");\n    }\n  }, [isDarkMode]);\n\n  // Initial Fetch\n  useEffect(() => {\n    if (\n      window.matchMedia &&\n      window.matchMedia(\"(prefers-color-scheme: dark)\").matches\n    ) {\n      setIsDarkMode(true);\n    }\n    fetchPosts();\n    const refresh = setInterval(fetchPosts, 30000);\n    return () => clearInterval(refresh);\n  }, []);\n\n  // Set focus on textarea when compose is opened\n  useEffect(() => {\n    if (isComposing && inputRef.current) {\n      inputRef.current.focus();\n    }\n  }, [isComposing]);\n\n  const fetchPosts = async () => {\n    try {\n      const res = await fetch(\"/api/posts\");\n      const data = await res.json();\n      if (res.ok) setPosts(data);\n    } catch (err) {\n      console.error(\"Failed to fetch posts\", err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!content.trim() || content.length > 500) return;\n    setIsSubmitting(true);\n    try {\n      const res = await fetch(\"/api/posts\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          content,\n          reply_to: replyingTo?.id || null,\n        }),\n      });\n      if (res.ok) {\n        setContent(\"\");\n        setReplyingTo(null);\n        setIsComposing(false);\n        fetchPosts();\n      }\n    } catch (err) {\n      console.error(\"Failed to post\", err);\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const handleInteract = async (id: string, action: \"up\" | \"down\") => {\n    try {\n      const res = await fetch(`/api/posts/${id}/interact`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ action }),\n      });\n\n      if (res.ok) {\n        setPosts((prev) =>\n          prev.map((p) => {\n            if (p.id === id) {\n              return {\n                ...p,\n                up_count: action === \"up\" ? p.up_count + 1 : p.up_count,\n                down_count: action === \"down\" ? p.down_count + 1 : p.down_count,\n              };\n            }\n            return p;\n          }),\n        );\n      } else {\n        const err = await res.json();\n        alert(err.error || \"Cannot interact again\");\n      }\n    } catch (err) {\n      console.error(\"Interaction failed\", err);\n    }\n  };\n\n  const handleReplyInit = (post: Post) => {\n    setReplyingTo(post);\n    setIsComposing(true);\n  };\n\n  // Group threads\n  const parents = posts.filter((p) => !p.reply_to);\n  const replies = posts.filter((p) => p.reply_to);\n\n  return (\n    <div className=\"min-h-screen bg-white dark:bg-[#0a0a0a] text-black dark:text-white font-sans selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black\">\n      {/* Sticky Header */}\n      <header className=\"sticky top-0 z-10 backdrop-blur-md bg-white/80 dark:bg-black/80 border-b border-gray-100 dark:border-gray-900 px-4 py-3\">\n        <div className=\"max-w-xl mx-auto w-full flex items-center justify-between\">\n          <h1 className=\"text-xl font-bold font-mono tracking-tight lowercase flex items-center gap-2\">\n            whisp\n          </h1>\n          <div className=\"flex items-center gap-4\">\n            <button\n              onClick={() => setIsDarkMode(!isDarkMode)}\n              className=\"text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white transition-colors cursor-pointer\"\n              aria-label=\"Toggle Theme\"\n            >\n              {isDarkMode ? <Sun className=\"w-5 h-5\" /> : <Moon className=\"w-5 h-5\" />}\n            </button>\n            <button\n              onClick={() => {\n                setReplyingTo(null);\n                setIsComposing(true);\n                window.scrollTo({ top: 0, behavior: \"smooth\" });\n              }}\n              className=\"bg-black text-white dark:bg-white dark:text-black p-1.5 rounded-full hover:opacity-80 transition-opacity cursor-pointer flex items-center justify-center\"\n              aria-label=\"New Post\"\n            >\n              <Plus className=\"w-5 h-5\" />\n            </button>\n          </div>\n        </div>\n      </header>\n\n      <div className=\"max-w-xl mx-auto w-full px-4 sm:px-0 py-6 flex flex-col gap-6 relative\">\n        {/* Feed */}\n        <main className=\"flex flex-col pb-36\">\n          {parents.length === 0 ? (\n            <div className=\"text-center py-20 text-gray-400 font-mono text-sm\">\n              The void is currently empty.\n            </div>\n          ) : (\n            parents.map((post) => (\n              <div key={post.id} className=\"relative\">\n                <PostCard\n                  post={post}\n                  onInteract={handleInteract}\n                  onReply={handleReplyInit}\n                  isDark={isDarkMode}\n                  replyCount={replies.filter((r) => r.reply_to === post.id).length}\n                />\n\n                {/* Render Replies below the parent */}\n                {replies.filter((r) => r.reply_to === post.id).length > 0 && (\n                  <div className=\"pl-6 md:pl-10 relative flex flex-col gap-0 border-l-2 border-gray-100 dark:border-gray-900 ml-4 mb-4 mt-[-10px]\">\n                    {replies\n                      .filter((r) => r.reply_to === post.id)\n                      .map((reply) => (\n                        <div key={reply.id} className=\"mt-4\">\n                          <PostCard\n                            post={reply}\n                            onInteract={handleInteract}\n                            onReply={() => handleReplyInit(post)}\n                            isDark={isDarkMode}\n                            replyCount={0}\n                          />\n                        </div>\n                      ))}\n                  </div>\n                )}\n              </div>\n            ))\n          )}\n        </main>\n      </div>\n\n      {/* Fixed Bottom Compose Area */}\n      {isComposing && (\n        <div className=\"fixed bottom-0 left-0 w-full z-20 px-4 pb-6 pt-4 bg-white/95 dark:bg-[#0a0a0a]/95 backdrop-blur-md border-t border-gray-200 dark:border-gray-800 animate-in slide-in-from-bottom-5\">\n          <div className=\"max-w-xl mx-auto\">\n            {replyingTo && (\n              <div className=\"mb-3 p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg flex items-start justify-between shadow-sm\">\n                <div className=\"flex flex-col gap-1 overflow-hidden\">\n                  <span className=\"text-xs font-semibold text-gray-500\">\n                    Replying to <bdi>{replyingTo.author_name}</bdi>\n                  </span>\n                  <p className=\"text-sm truncate opacity-80\">\n                    {replyingTo.content}\n                  </p>\n                </div>\n                <button\n                  onClick={() => setReplyingTo(null)}\n                  className=\"text-gray-400 hover:text-black dark:hover:text-white p-1 cursor-pointer flex-shrink-0\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n            )}\n            <form onSubmit={handleSubmit} className=\"flex flex-col gap-3\">\n              <div className=\"flex items-end gap-2 bg-white dark:bg-[#111] border border-gray-300 dark:border-gray-700 rounded-2xl p-2 shadow-sm focus-within:ring-2 focus-within:ring-black dark:focus-within:ring-white focus-within:border-transparent transition-all\">\n                <textarea\n                  ref={inputRef}\n                  className=\"w-full bg-transparent resize-none border-none p-2 max-h-[150px] min-h-[44px] text-base placeholder-gray-400 dark:placeholder-gray-600 outline-none flex-1 py-2.5\"\n                  placeholder={\n                    replyingTo\n                      ? \"Write your reply...\"\n                      : \"Whisper something to the void...\"\n                  }\n                  value={content}\n                  onChange={(e) => setContent(e.target.value)}\n                  maxLength={500}\n                  onKeyDown={(e) => {\n                    if (e.key === \'Enter\' && !e.shiftKey) {\n                      e.preventDefault();\n                      if (content.trim()) handleSubmit(e);\n                    }\n                  }}\n                />\n                \n                <button\n                  type=\"submit\"\n                  disabled={!content.trim() || isSubmitting}\n                  className=\"flex-shrink-0 p-3 bg-black dark:bg-white text-white dark:text-black rounded-xl hover:opacity-80 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer mb-0.5\"\n                  aria-label=\"Send whisper\"\n                >\n                  <Send className=\"w-4 h-4\" />\n                </button>\n              </div>\n              \n              <div className=\"flex items-center justify-between px-2\">\n                <span\n                  className={cn(\n                    \"text-xs font-mono\",\n                    content.length > 450 ? \"text-red-500\" : \"text-gray-400\",\n                  )}\n                >\n                  {content.length} / 500\n                </span>\n                <button\n                  type=\"button\"\n                  onClick={() => {\n                    setIsComposing(false);\n                    setReplyingTo(null);\n                    setContent(\'\');\n                  }}\n                  className=\"text-xs font-mono text-gray-500 hover:text-black dark:hover:text-white transition-colors cursor-pointer\"\n                >\n                  Cancel\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"
      }
      num_matches: 1
    }
  }
}
